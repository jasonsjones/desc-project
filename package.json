{
    "private": true,
    "name": "desc",
    "workspaces": [
        "packages/api",
        "packages/app"
    ],
    "scripts": {
        "bootstrap": "lerna bootstrap",
        "dev": "lerna run dev --stream",
        "dev:api": "lerna run dev --stream --scope @desc/api",
        "dev:app": "lerna run dev --stream --scope @desc/app",
        "lint": "lerna run lint --stream",
        "postinstall": "yarn bootstrap",
        "test": "yarn test:api && yarn test:app",
        "test:api": "lerna run test:unit --stream --scope @desc/api",
        "test:app": "lerna run test --stream --scope @desc/app"
    },
    "license": "MIT",
    "devDependencies": {
        "lerna": "^3.16.1"
    },
    "engines": {
        "node": "10.16.0",
        "yarn": "1.16.0"
    }
}
